# Copy to .env and edit. run.sh creates it for you if missing.

# ── rubixgoplatform release ────────────────────────────────────────────────
# Node version to download. Bump to any tag at
# github.com/rubixchain/rubixgoplatform/releases to upgrade.
RUBIX_VERSION=v1.0.0

# Rubix network to join: testnet | mainnet | localnet
NETWORK_MODE=testnet

# Postgres major version (official postgres image tag). Changing this on an existing
# node is not in-place — wipe and start fresh (./node.sh down --wipe; up).
POSTGRES_VERSION=18

# ── ports ──────────────────────────────────────────────────────────────────
# Host port for the node HTTP API (rubixgoplatform always runs on 20000 inside
# the container; this is the port YOU connect to).
API_PORT=20000
# Interface the API is published on. 127.0.0.1 = local only (safe default).
# Set to 0.0.0.0 ONLY if a remote backend must reach it — and firewall it,
# the API has no authentication.
API_BIND=127.0.0.1

# Host port for the libp2p / IPFS swarm (P2P). This MUST be open to the internet
# (and port-forwarded if behind NAT) so other nodes/quorums can reach you.
SWARM_PORT=4002

# Host port for Postgres (kept on localhost; you normally never touch this).
PG_PORT=5432

# ── networking ─────────────────────────────────────────────────────────────
# Public (or LAN) IP announced to the DHT so peers can dial in.
# Leave blank — run.sh auto-detects it.
EXTERNAL_IP=

# ── storage ────────────────────────────────────────────────────────────────
# Where node data + Postgres are stored (must persist across restarts).
# Relative (./data) or absolute (/mnt/rubix-data). Created if missing.
DATA_PATH=./data

# Name prefix for the containers (lets you run more than one set on a host).
NODE_NAME=rubix
